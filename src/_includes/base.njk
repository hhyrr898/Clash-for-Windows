<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set docTitle = title or site.name %}
    {% set metaDescription = description or site.description %}
    {% set canonical = site.url + (canonicalUrl or page.url or "/") %}
    <title>{{ docTitle }}</title>
    <meta name="description" content="{{ metaDescription }}">
    {% if noindex %}
    <meta name="robots" content="noindex,follow">
    {% else %}
    <meta name="robots" content="index,follow,max-image-preview:large">
    {% endif %}
    <link rel="canonical" href="{{ canonical }}">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="stylesheet" href="/assets/styles.css">
    <meta property="og:title" content="{{ docTitle }}">
    <meta property="og:description" content="{{ metaDescription }}">
    <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:image" content="{{ cover or site.logo }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:locale" content="zh_CN">
    <meta name="twitter:card" content="summary_large_image">
    <script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.name,
  "url": site.url,
  "description": site.description
} | dump | safe }}
    </script>
    {% if video %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "VideoObject",
        "name": "{{ title }}",
        "description": "{{ description }}",
        "thumbnailUrl": ["{{ cover }}"],
        "uploadDate": "{{ page.date | htmlDate }}",
        "embedUrl": "{{ video.embed }}"
      }
    </script>
    {% endif %}
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-shell">
        <a class="brand" href="/">
          <img src="{{ site.logo }}" alt="Clash for Windows 标识" width="48" height="48">
          <span>Clash for Windows</span>
        </a>
        <nav class="main-nav" aria-label="主导航">
          <a href="/">首页</a>
          <a href="/dows.html">下载中心</a>
          <a href="/blog/">博客</a>
          <a href="/tags/">Tags</a>
        </nav>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <section>
          <h2>Clash for Windows</h2>
          <p>整理跨平台客户端资料、安装步骤、配置思路与日常使用记录。</p>
        </section>
        <nav aria-label="底部导航">
          <a href="/">Clash for Windows 资源中心</a>
          <a href="/blog/">Clash for Windows 使用笔记</a>
          <a href="/dows.html">Clash for Windows 下载中心</a>
          <a href="/sitemap.xml">站点地图</a>
        </nav>
      </div>
    </footer>
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js" defer></script>
    <script>window.addEventListener("load",function(){if(window.LA){LA.init({id:"3LYbKlm7CWKiFWs3",ck:"3LYbKlm7CWKiFWs3"})}})</script>
  </body>
</html>
