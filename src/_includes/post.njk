---
layout: base.njk
---
<article class="post-hero">
  <div class="container post-header">
    <p class="eyebrow">Clash for Windows Guide</p>
    <h1>{{ title }}</h1>
    <p>{{ description }}</p>
    <p class="post-meta">{{ page.date | readableDate }}{% if updated %} · 更新于 {{ updated }}{% endif %}</p>
    <div class="tag-row">
      {% for tag in tags | publicTags %}
      <a href="/tags/{{ tag | tagSlug }}/">{{ tag }}</a>
      {% endfor %}
    </div>
    <img class="post-cover" src="{{ cover }}" alt="{{ title }}封面图" width="960" height="560" loading="eager">
  </div>
</article>

<section class="section-block">
  <div class="container post-layout">
    <div class="post-content">
      {{ content | safe }}
      {% if video %}
      <h2>{{ title }}视频教程</h2>
      <p>{{ video.description }}</p>
      <iframe class="video-frame" src="{{ video.embed }}" title="{{ title }}" loading="lazy" allowfullscreen></iframe>
      {% endif %}
    </div>
    <aside class="side-panel">
      <h2>目录</h2>
      <a href="/blog/">返回博客</a>
      <a href="/dows.html">下载中心</a>
      <a href="/tags/">Tags</a>
    </aside>
  </div>
</section>

<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": page.date | htmlDate,
  "dateModified": updated or (page.date | htmlDate),
  "author": {
    "@type": "Organization",
    "name": site.author
  },
  "publisher": {
    "@type": "Organization",
    "name": site.name,
    "url": site.url
  },
  "mainEntityOfPage": site.url + page.url
} | dump | safe }}
</script>
<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "首页",
      "item": site.url + "/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "博客",
      "item": site.url + "/blog/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": site.url + page.url
    }
  ]
} | dump | safe }}
</script>
