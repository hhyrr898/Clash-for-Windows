<section class="section-block" id="latest">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Recent Articles</p>
      <h2>Clash for Windows 文章更新</h2>
      <a href="/blog/">进入博客</a>
    </div>
    <div class="article-grid">
      {% for post in collections.postsByDate | limit(12) %}
      <article class="article-card">
        <a href="{{ post.url }}" aria-label="阅读{{ post.data.title }}">
          <img src="{{ post.data.cover }}" alt="{{ post.data.title }}配图" width="420" height="260" loading="lazy">
        </a>
        <div>
          <time datetime="{{ post.date | htmlDate }}">{{ post.date | readableDate }}</time>
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <p>{{ post.data.description }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section-block muted" id="scenes">
