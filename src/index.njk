    <div class="section-heading">
      <p class="eyebrow">Download Center</p>
      <h2>平台版本</h2>
      <a href="/dows.html">查看全部版本</a>
    </div>
    <div class="download-strip">
      {% set platforms = [
        ["Windows 版", "Clash for Windows Windows 版安装包", "适合 Windows 10 / 11 桌面环境，提供基础配置与启动说明。", "windows-ban", "/blog/clash-for-windows-install-guide/"],
        ["macOS 配置参考", "Clash for Windows macOS 配置参考", "适合苹果电脑用户查看相近桌面代理客户端准备流程。", "macos-ban", "/blog/clash-for-windows-macos-setup/"],
        ["Android 配置参考", "Clash for Windows Android 配置参考", "适合移动端场景，整理导入订阅与网络切换要点。", "android-ban", "/blog/clash-for-windows-android-guide/"],
        ["iOS 配置参考", "Clash for Windows iOS 配置参考", "适合 iPhone 与 iPad 用户了解相近客户端使用方式。", "ios-ban", "/blog/clash-for-windows-ios-guide/"]
      ] %}
      {% for item in platforms %}
      <article class="mini-card">
        <a href="{{ item[4] }}" aria-label="阅读{{ item[0] }}相关文章">
          <img src="https://tse-mm.bing.com/th?q={{ item[1] | urlEncode }}" alt="{{ item[1] }}示意图" width="320" height="200" loading="lazy">
        </a>
        <h3>{{ item[0] }}</h3>
        <p>{{ item[2] }}</p>
        <a href="/dows.html#{{ item[3] }}">查看详情</a>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section-block muted" id="guide">
  <div class="container two-column">
    <article>
      <p class="eyebrow">目录</p>
      <h2>Clash for Windows 使用目录</h2>
      <p>按准备、安装、配置、排查、日常使用拆分内容，方便新用户从第一步开始，也方便老用户快速定位需要的说明。</p>
