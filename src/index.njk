        ["启动项设置", "Clash for Windows 开机启动", "根据个人电脑习惯决定是否随系统启动。", "/blog/clash-for-windows-startup/"],
        ["日志查看", "Clash for Windows 日志查看", "通过日志判断订阅、端口和网络状态。", "/blog/clash-for-windows-log-reading/"],
        ["便携使用", "Clash for Windows 便携设置", "适合多台电脑之间迁移配置文件的用户。", "/blog/clash-for-windows-update-notes/"],
        ["移动协同", "Clash for Windows 多设备协同", "让桌面端与移动端保持相近的使用方式。", "/blog/clash-for-windows-android-guide/"]
      ] %}
      {% for scene in scenes %}
      <article class="feature-card">
        <a href="{{ scene[3] }}" aria-label="阅读{{ scene[0] }}相关文章">
          <img src="https://tse-mm.bing.com/th?q={{ scene[1] | urlEncode }}" alt="{{ scene[1] }}场景图" width="360" height="220" loading="lazy">
        </a>
        <h3><a href="{{ scene[3] }}">{{ scene[0] }}</a></h3>
